# Expo public env vars consumed by src/lib/supabase/env.ts.
# Both are required for full backend mode (persistence + Edge Functions).
# If either is missing, getSupabaseClient() returns null and the app runs
# in offline/mock mode.
#
# The value of EXPO_PUBLIC_SUPABASE_ANON_KEY can be either the legacy
# anon key OR a new publishable key (sb_publishable_...). Both work as
# the client-side apikey.

EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-or-publishable-key>
